# Copy this file to `.streamlit/secrets.toml` (which is git-ignored) for local
# use, or paste these keys into the Streamlit Community Cloud "Secrets" box.

# Require a password to open the app. Remove/leave blank to run without a gate.
APP_PASSWORD = "change-me"

# Optional: shrink the Whisper model if the host is low on RAM ("base" | "small" | "medium").
# WHISPER_MODEL_SIZE = "base"
